# Copy this file to .env and fill in your values

OPENAI_API_KEY=your-openai-api-key-here

# Main chat model
MODEL_NAME=gpt-3.5-turbo

# Model used for summarizing old conversation history
SUMMARIZER_MODEL_NAME=gpt-3.5-turbo

# Token threshold before old messages get summarized
SUMMARY_TOKEN_THRESHOLD=1000

